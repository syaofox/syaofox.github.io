    <item>
      <title>Rsync 命令比对文件及增量同步</title>
      <link>https://syaofox.github.io/post/rsync%E5%91%BD%E4%BB%A4%E6%AF%94%E5%AF%B9%E6%96%87%E4%BB%B6%E5%8F%8A%E5%A2%9E%E9%87%8F%E5%90%8C%E6%AD%A5/</link>
